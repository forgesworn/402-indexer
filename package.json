{
  "name": "402-indexer",
  "version": "0.2.2",
  "description": "Nostr-native crawler that discovers L402 and x402 paid APIs and publishes kind 31402 events",
  "type": "module",
  "main": "dist/orchestrator.js",
  "bin": {
    "402-indexer": "dist/orchestrator.js"
  },
  "private": true,
  "files": [
    "dist"
  ],
  "publishConfig": {
    "provenance": true
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
