    "node": ">=20"
  },
  "dependencies": {
    "nostr-tools": "^2.12.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "funding": {
    "type": "lightning",
    "url": "lightning:thedonkey@strike.me"
